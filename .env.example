# MCP Streamable HTTP 监听（mcp_server.py）
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ---------- 163 邮箱必须按下面方式填，否则容易 "Connection unexpectedly closed" ----------
# SMTP_USER / EMAIL_FROM 必须是「完整邮箱」，不能只有用户名，也不能把授权码写到 FROM 里
# SMTP_PASSWORD 填 163 设置里的「客户端授权码」，不是网页登录密码
#
# 推荐 465 SSL（更稳）：
#   SMTP_SERVER=smtp.163.com
#   SMTP_PORT=465
#   SMTP_SSL=true
#
# 若坚持用 587：可设 SMTP_USE_STARTTLS=true 强制走 STARTTLS（否则网易会自动改用 465，不再先连 587）

SMTP_SERVER=smtp.163.com
SMTP_PORT=465
SMTP_SSL=true
SMTP_USER=yourname@163.com
SMTP_PASSWORD=your_authorization_code
DEFAULT_SENDER=yourname@163.com

# 调试 SMTP 握手时可打开（日志会很多）
# SMTP_DEBUG=1
# 关闭 587 失败自动改 465 时设 false
# SMTP_FALLBACK_465=false
